# Copy to .env and set real values. Never commit .env.
# See repo SKILL.md for correct paths (Bearer auth, lng/lat for direction, style.json).
GRABMAPS_API_KEY=
NEXT_PUBLIC_GRABMAPS_API_KEY=
# API gateway root (default https://maps.grab.com) — no trailing slash
GRABMAPS_BASE_URL=https://maps.grab.com
# Browser: same as GRABMAPS_BASE_URL; style is GET {base}/api/style.json + Bearer
NEXT_PUBLIC_GRABMAPS_BASE_URL=https://maps.grab.com
# Next.js and FastAPI
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
# Local `next dev` + remote API: set to 1 to use same-origin /api/ride (needs RIDE_API_UPSTREAM). Omit NEXT_PUBLIC_WS_URL so WSS is taken from /api/ride-ws-origin.
# NEXT_PUBLIC_RIDE_VIA_BFF=1
# Vercel (or any hosted Next app): the browser should NOT call a raw EC2 IP over https (self-signed).
# Leave NEXT_PUBLIC_API_URL as localhost, or set RIDE_API_UPSTREAM and use the BFF (see below).
# Server-only: where Next proxies /api/ride to (no trailing slash). e.g. https://54.169.70.247 or a domain.
RIDE_API_UPSTREAM=
# If upstream uses a self-signed cert, set 1 on Vercel (server-side fetch only; not the browser).
# Needed when EC2 nginx was reset to the repo template after deploy (before re-running letsencrypt-bootstrap.sh).
RIDE_API_TLS_INSECURE=0
# Optional: use inline fixture instead of live directions (0 or 1)
USE_DIRECTIONS_FIXTURE=0
# Place search: Grab POI when GRABMAPS_API_KEY is set; otherwise OSM Nominatim (Singapore only).
# Route geometry: Grab Directions with key; otherwise public OSRM for chosen start/end.
